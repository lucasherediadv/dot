if has("eval")
  let skip_defautls_vim=1
endif

set nocompatible

let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
let g:loaded_matchparen=1

filetype plugin indent on
syntax on 
colorscheme habamax

" general settings
set number
set relativenumber
set list
set listchars=tab:→\ ,trail:·
set wrap
set linebreak
set expandtab
set autoindent
set smarttab
set smartindent
set tabstop=2
set softtabstop=2
set shiftwidth=2
set nohlsearch
set noincsearch
set noignorecase
set nobackup
set noswapfile
set nowritebackup

