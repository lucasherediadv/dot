set nocompatible

filetype plugin on
filetype indent on
syntax on

colorscheme habamax

set autoindent
set expandtab
set softtabstop=2
set shiftwidth=2
set relativenumber
set linebreak
set wrap
set nobackup
set noswapfile
set nowritebackup
set viminfofile=$HOME/.vim/viminfo

augroup custom_indentation
  autocmd!
  autocmd FileType python setlocal shiftwidth=4 softtabstop=4
  autocmd Filetype go setlocal shiftwidth=4 softtabstop=4
augroup END

