if has("eval")
  let skip_defautls_vim=1
endif

if &compatible
  set nocompatible
endif

filetype plugin indent on
syntax on

let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
let g:loaded_matchparen=1

colorscheme habamax

set relativenumber
set expandtab
set autoindent
set smarttab
set smartindent
set tabstop=2
set softtabstop=2
set shiftwidth=2
set ignorecase
set nowrap
set nohlsearch
set noincsearch
set nobackup
set noswapfile
set nowritebackup

