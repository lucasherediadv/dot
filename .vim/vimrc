set nocompatible

filetype plugin on
filetype indent on
syntax on

let g:loaded_matchparen=1
let g:loaded_netrw=1
let g:loaded_netrwPlugin=1

colorscheme habamax

set noshowmode
set autoindent
set expandtab
set softtabstop=2
set shiftwidth=2
set number
set relativenumber
set linebreak
set wrap
set nobackup
set noswapfile
set nowritebackup
set viminfofile=$HOME/.vim/viminfo

" Clear highlight search
map <silent> <esc><esc> :noh<cr>
set incsearch
set ignorecase

" Indentation configuration per filetype
augroup custom_indentation
  autocmd!
  autocmd FileType python setlocal shiftwidth=4 softtabstop=4
  autocmd Filetype go setlocal shiftwidth=4 softtabstop=4
augroup END

