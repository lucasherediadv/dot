" Do not use Vi defaults 
set nocompatible

" Load plugins, set colors, enable syntax
filetype plugin indent on
colorscheme atlas
syntax on

" Unnecessary
let g:loaded_matchparen=1
let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
set noshowmatch
set noshowmode
set nobackup
set noswapfile
set nowritebackup
set nohlsearch
set noincsearch

" General options
set autoindent
set expandtab
set softtabstop=2
set shiftwidth=2
set relativenumber
set linebreak
set wrap
set viminfofile=$HOME/.vim/viminfo
set ignorecase

" Indentation exceptions
augroup custom_indentation
  autocmd!
  autocmd FileType python setlocal shiftwidth=4 softtabstop=4
  autocmd Filetype go setlocal shiftwidth=4 softtabstop=4
augroup END

