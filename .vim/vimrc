set nocompatible

filetype plugin on
filetype indent on
syntax on

" Colorful theme for colorful souls
colorscheme atlas

set noshowmode
set autoindent
set expandtab
set softtabstop=2
set shiftwidth=2
set relativenumber
set linebreak
set wrap

" Files
set nobackup
set noswapfile
set nowritebackup
set viminfofile=$HOME/.vim/viminfo

" Search
set nohlsearch
set noincsearch
set ignorecase

" Indentation configuration per filetype
augroup custom_indentation
  autocmd!
  autocmd FileType python setlocal shiftwidth=4 softtabstop=4
  autocmd Filetype go setlocal shiftwidth=4 softtabstop=4
augroup END

